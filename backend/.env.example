# ── LLM (pick one) ──────────────────────────────────
# Local: Ollama (default when GROQ_API_KEY is empty)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Cloud: Groq (free tier — set this to enable cloud mode)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# ── Vector DB (pick one) ────────────────────────────
# Local: file storage (default when QDRANT_URL is empty)
QDRANT_PATH=./data/qdrant

# Cloud: Qdrant Cloud (free tier — set URL to enable)
QDRANT_URL=
QDRANT_API_KEY=

# ── Auth ────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Shared settings ─────────────────────────────────
COLLECTION_NAME=medical_papers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
PUBMED_EMAIL=your-email@example.com

CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7
